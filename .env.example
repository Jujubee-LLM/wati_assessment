# Required for the default LLM-backed planner.
# Use --provider fallback only for explicit offline deterministic demos.
DASHSCOPE_API_KEY=
QWEN_MODEL=qwen-plus
QWEN_TIMEOUT_SECONDS=90
QWEN_MAX_RETRIES=2

# Optional. Required only when running with --client real.
# Prefer the full API Endpoint URL from WATI API Docs if available.
WATI_API_BASE_URL=
WATI_TENANT_ID=
WATI_TOKEN=
